\name{write_input_template_guide}
\alias{write_input_template_guide}
\title{Write the raw input template guide}
\usage{
write_input_template_guide(
  spec,
  output_dir = "pmslt_inputs_raw",
  templates = NULL,
  overwrite = FALSE
)
}
\arguments{
\item{spec}{A \code{pmslt_spec} object.}

\item{output_dir}{Directory where \code{README_inputs_raw.md} should be written.}

\item{templates}{Optional named list of templates. If omitted, templates are
rebuilt from \code{spec}.}

\item{overwrite}{Logical. Should an existing guide be overwritten?}
}
\value{
Invisibly returns the guide path.
}
\description{
Writes a markdown guide explaining how to fill every CSV generated by
\code{draft_input_templates()}. The guide is designed for beginners who are
collecting PMSLT model inputs for the first time.
}
